# ===========================
# Variables d'environnement — Staging
# ===========================
# Copier ce fichier vers .env.staging et renseigner les valeurs.
# Ne jamais commiter de secrets dans le dépôt.

# --- Backend (apps/api) ---
NODE_ENV=staging
PORT=3000
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CORS_ALLOWED_ORIGINS=

# --- CI/CD ---
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
RENDER_API_KEY=

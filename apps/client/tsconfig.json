{
  "extends": "../../tsconfig.base.json",
  "compileOnSave": false,
  "compilerOptions": {
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "isolatedModules": true,
    "importHelpers": true,
    "module": "preserve",
    "rootDir": "../..",
    "paths": {
      "@kraak/web/*": ["./projects/web/src/*"],
      "@kraak/mobile/*": ["./projects/mobile/src/*"],
      "@kraak/tokens": ["../../packages/tokens/src/index.ts"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    { "path": "./projects/web/tsconfig.app.json" },
    { "path": "./projects/web/tsconfig.spec.json" },
    { "path": "./projects/mobile/tsconfig.app.json" }
  ]
}

# ===========================
# Variables d'environnement — Client (local)
# ===========================
# Copier ce fichier vers .env.local pour le local, ou vers .env.staging
# pour le staging, puis adapter les valeurs.
#
# Note : Angular utilise des fichiers environment.ts compilés à la build,
# pas des variables .env à l'exécution.
# Ce fichier concerne uniquement les scripts, le runtime-config et les tests E2E.

# API publique consommée par le client
CLIENT_API_BASE_URL=http://localhost:3000

# Supabase public côté client
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=

# Port du serveur de développement Angular (utilisé par Playwright)
KRAAK_WEB_PORT=4200

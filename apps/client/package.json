{
  "name": "@kraak/client",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "clean": "node ../../scripts/clean.mjs",
    "ng": "ng",
    "seo:generate": "node ../../scripts/generate-web-seo.mjs",
    "runtime-config:generate": "pnpm run runtime-config:generate:local",
    "runtime-config:generate:local": "node ../../scripts/generate-client-runtime-config.mjs --env local",
    "runtime-config:generate:staging": "node ../../scripts/generate-client-runtime-config.mjs --env staging",
    "runtime-config:generate:production": "node ../../scripts/generate-client-runtime-config.mjs --env production",
    "dev": "pnpm --dir ../.. dev",
    "predev:web": "pnpm run seo:generate && pnpm run runtime-config:generate:local",
    "dev:web": "ng serve web --configuration local",
    "dev:web:staging": "pnpm run seo:generate && pnpm run runtime-config:generate:staging && ng serve web --configuration staging",
    "start": "pnpm run dev:web",
    "build": "pnpm run build:web",
    "prebuild:web": "pnpm run seo:generate && pnpm run runtime-config:generate:production",
    "build:web": "ng build web",
    "build:web:local": "pnpm run seo:generate && pnpm run runtime-config:generate:local && ng build web --configuration local",
    "build:web:staging": "pnpm run seo:generate && pnpm run runtime-config:generate:staging && ng build web --configuration staging",
    "predev:mobile": "pnpm run runtime-config:generate:local",
    "dev:mobile": "ng serve mobile --configuration local",
    "dev:mobile:staging": "pnpm run runtime-config:generate:staging && ng serve mobile --configuration staging",
    "prebuild:mobile": "pnpm run runtime-config:generate:production",
    "build:mobile": "ng build mobile",
    "build:mobile:local": "pnpm run runtime-config:generate:local && ng build mobile --configuration local",
    "build:mobile:staging": "pnpm run runtime-config:generate:staging && ng build mobile --configuration staging",
    "cap:sync": "cap sync",
    "cap:copy": "cap copy",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "build:debug:android": "pnpm build:mobile && node ../../scripts/ensure-capacitor-platform.mjs android && cap sync android",
    "build:debug:ios": "pnpm build:mobile && node ../../scripts/ensure-capacitor-platform.mjs ios && cap sync ios",
    "watch": "ng build --watch --configuration local",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "serve:ssr:web": "node dist/web/server/server.mjs"
  },
  "dependencies": {
    "@angular/animations": "^21.2.8",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.7",
    "@capacitor/android": "^7.3.0",
    "@capacitor/core": "^7.3.0",
    "@ionic/angular": "^8.6.0",
    "@ionic/core": "8.8.3",
    "@kraak/api-client": "workspace:*",
    "@kraak/contracts": "workspace:*",
    "@kraak/tokens": "workspace:*",
    "@primeuix/themes": "^2.0.3",
    "@stencil/core": "^4.43.3",
    "express": "^5.1.0",
    "ionicons": "^7.4.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.5",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@capacitor/cli": "^7.3.0",
    "@eslint/js": "^10.0.1",
    "@ionic/angular-toolkit": "^12.1.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "angular-eslint": "^21.3.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.0.8"
  }
}

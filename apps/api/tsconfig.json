{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "forceConsistentCasingInFileNames": true,
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo"
  }
}

# ===========================
# Variables d'environnement — API (local)
# ===========================
# Copier ce fichier vers .env.local et renseigner les valeurs.
# Le fallback .env reste toléré pour compatibilité, mais .env.local
# est désormais la référence locale.
# Ne jamais commiter de secrets dans le dépôt.

NODE_ENV=local
PORT=3000

# Supabase
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Resend (envoi d'e-mails)
RESEND_API_KEY=
CONTACT_TO_EMAIL=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4300

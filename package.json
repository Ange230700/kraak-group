{
  "name": "kraak-group",
  "version": "0.0.0",
  "private": true,
  "description": "KRAAK — Monorepo for the web platform, API, and shared packages",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "clean": "pnpm -r clean && node ./scripts/clean.mjs",
    "dev": "node ./scripts/dev-all.mjs",
    "build": "pnpm build:web && pnpm build:mobile && pnpm build:api",
    "test": "pnpm test:libs && pnpm test:api && pnpm test:unit && pnpm test:e2e",
    "dev:web": "pnpm --filter @kraak/client run dev:web",
    "build:web": "pnpm --filter @kraak/client build",
    "dev:mobile": "pnpm --filter @kraak/client run dev:mobile --port 4300",
    "build:mobile": "pnpm --filter @kraak/client build:mobile",
    "dev:api": "pnpm --filter @kraak/api dev",
    "build:api": "pnpm --filter @kraak/api build",
    "test:api": "pnpm --filter @kraak/api test",
    "test:libs": "pnpm -r --filter @kraak/contracts --filter @kraak/domain --filter @kraak/api-client --filter @kraak/tokens test",
    "lint:api": "pnpm --filter @kraak/api lint",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "typecheck:web": "pnpm --filter @kraak/client exec tsc --noEmit -p projects/web/tsconfig.app.json",
    "typecheck:mobile": "pnpm --filter @kraak/client exec tsc --noEmit -p projects/mobile/tsconfig.app.json",
    "typecheck:api": "pnpm --filter @kraak/api exec tsc --noEmit -p tsconfig.build.json",
    "typecheck": "pnpm typecheck:web && pnpm typecheck:mobile && pnpm typecheck:api",
    "test:unit": "pnpm --filter @kraak/client test",
    "test:e2e": "pnpm --filter @kraak/client e2e",
    "format": "prettier --write \"**/*.{ts,html,scss,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,html,scss,css,json,md}\"",
    "commit": "git-cz",
    "prepare": "husky"
  },
  "validate-branch-name": {
    "pattern": "^(main|(feat|fix|chore|docs|test|refactor|ci|style|perf|revert|build)/.+)$",
    "errorMsg": "Le nom de branche doit suivre le format <type>/<sujet> (ex: feat/login-page, fix/header-layout) ou être 'main'"
  },
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
  },
  "cz-git": {
    "disableEmoji": true,
    "useEmoji": false,
    "allowCustomScopes": false,
    "scopes": [
      "root",
      "repo",
      "workspace",
      "config",
      "docs",
      "scripts",
      "web",
      "mobile",
      "api",
      "client",
      "contracts",
      "domain",
      "api-client",
      "tokens",
      "infra",
      "ci"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "validate-branch-name": "^1.3.2"
  }
}
